<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dluznicek_Lite.SouhrnPage"
             Title="Účet">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label Text="🧾 Kdo co platí 🧾" 
               FontSize="28" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />

        <CollectionView x:Name="VysledkyView" HeightRequest="400">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,5" Padding="15"  BackgroundColor="#F8F9FA">
                        <Grid ColumnDefinitions="2*, Auto, Auto, Auto" ColumnSpacing="10">

                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="{Binding Jmeno}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Detail}" FontSize="14" TextColor="Gray" />
                            </VerticalStackLayout>

                            <Label Text="{Binding CastkaKc, StringFormat='{0} Kč'}" 
                                    FontSize="20" 
                                    FontAttributes="Bold" 
                                    TextColor="{Binding BarvaTextu}" 
                                    VerticalOptions="Center" 
                                    HorizontalOptions="End" 
                                    Grid.Column="2" />

                            <Button Text="Zaplatit" 
                                    Clicked="OnZaplatilKliknuto" 
                                    CommandParameter="{Binding .}" 
                                    Grid.Column="3" 
                                    Padding="5,3" 
                                    HeightRequest="40" 
                                    VerticalOptions="Center"
                                    BackgroundColor="#0078D4"
                                    CornerRadius="5"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label x:Name="CelkemVybranoLabel" 
               FontSize="22" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               TextColor="DarkGreen" />

    </VerticalStackLayout>
</ContentPage>